{
    "auto_update_extensions": {
        "assembly": false,
    },
    "cli_default_open_behavior": "existing_window",
    "icon_theme": "Warm Charmed Icons", // sets icon theme
    "theme": "One Dark", // sets theme
    "theme_overrides": {
        // overrides theme features
        "One Dark": {
            "border.variant": "#282c33ff",
            "border": "#282c33ff",
            "title_bar.background": "#282c33ff",
            "status_bar.background": "#282c33ff",
            "panel.background": "#282c33ff",
            "panel.focused_border": "#4E466E",
            "tab_bar.background": "#282c33ff",
            "tab.active_background": "#282c33ff",
            "tab.inactive_background": "#282c33ff",
            "background": "#282c33ff",
        },
    },
    "title_bar": {
        // sets title bar properties
        "show_onboarding_banner": false,
        "show_project_items": false,
        "show_branch_name": false,
    },
    "tab_bar": {
        // sets tab bar properties
        "show": false,
    },
    "toolbar": {
        // sets toolbar properties
        // "quick_actions": false,
    },
    "status_bar": {
        // sets status bar properties
        // "experimental.show": false,
    },
    "project_panel": {
        // sets project panel properties
        "dock": "right",
        "hide_root": true,
        "default_width": 300,
        "auto_fold_dirs": false,
        "scrollbar": {
            "show": "never",
        },
        "indent_guides": {
            "show": "never",
        },
    },
    "outline_panel": {
        // sets outline panel properties
        "dock": "right",
        "default_width": 300,
        "indent_guides": {
            "show": "never",
        },
    },
    "file_finder": {
        // sets file finder properties
        "modal_max_width": "xlarge",
    },
    "scrollbar": {
        // sets scrollbar properties
        "show": "never",
    },
    "gutter": {
        // sets gutter properties
        "min_line_number_digits": 0,
        "folds": false,
    },
    "indent_guides": {
        // sets indent guides properties
        "enabled": false,
    },
    "terminal": {
        // sets teminal height properties
        "default_height": 9999,
    },
    "ui_font_family": ".ZedSans", // sets ui font family
    "ui_font_size": 17.0, // sets ui font size
    "ui_font_weight": 500.0, // sets ui font weight
    "buffer_font_family": ".ZedMono", // sets buffer font family
    "buffer_font_size": 15, // sets buffer font size
    "buffer_font_weight": 500.0, // sets buffer font weight
    "buffer_font_features": {
        // sets font ligatures to false
        "calt": false,
    },
    "buffer_line_height": "standard", // sets buffer line height
    "vim_mode": true, // sets vim mode true
    "selection_highlight": false,
    "current_line_highlight": "none",
    "show_whitespaces": "none",
    "tab_size": 4,
    "auto_indent_on_paste": false,
    "autosave": {
        "after_delay": {
            "milliseconds": 500,
        },
    },
    "extend_comment_on_newline": false,
    "soft_wrap": "editor_width", // soft wraps
    "when_closing_with_no_tabs": "keep_window_open",
    "close_on_file_delete": true,
    "restore_on_startup": "launchpad",
    "session": {
        "restore_unsaved_buffers": false,
    },
    "disable_ai": true, // disables AI

    //python lsp set up
    "languages": {
        "Python": {
            "language_servers": ["ty", "!basedpyright"],
        },
    },
}